# =============================================================================
# App Configuration
# =============================================================================
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# =============================================================================
# Supabase (Required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database connection (for LangGraph checkpointer)
# Use pooler URL for Vercel (port 6543 with ?pgbouncer=true)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL_POOLER=postgresql://postgres:password@db.xxx.supabase.co:6543/postgres?pgbouncer=true

# =============================================================================
# API Keys (Optional: overrides API keys globally for all users)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=

# OpenAI Organization
NEXT_PUBLIC_OPENAI_ORGANIZATION_ID=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_GPT_35_TURBO_NAME=
AZURE_GPT_45_VISION_NAME=
AZURE_GPT_45_TURBO_NAME=
AZURE_EMBEDDINGS_NAME=

# =============================================================================
# Vercel Cron Jobs
# =============================================================================
CRON_SECRET=

# =============================================================================
# LangSmith Tracing (Optional)
# =============================================================================
LANGSMITH_API_KEY=
LANGSMITH_WORKSPACE_ID=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=health-plan-agent
LANGCHAIN_TRACING_V2=false
LANGCHAIN_CALLBACKS_BACKGROUND=false

# =============================================================================
# General Configuration (Optional)
# =============================================================================
EMAIL_DOMAIN_WHITELIST=
EMAIL_WHITELIST=

# File size limit for uploads in bytes (default: 10MB)
NEXT_PUBLIC_USER_FILE_SIZE_LIMIT=10485760

# Ollama (local only - not used in Vercel)
# NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
